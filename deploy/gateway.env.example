# Copy this file to deploy/gateway.env before running docker compose.

# Required when binding the gateway to 0.0.0.0.
PRODEX_GATEWAY_TOKEN=change-me

# Optional trusted reverse-proxy SSO for admin endpoints.
# PRODEX_GATEWAY_SSO_PROXY_TOKEN=replace-me

# Optional native OIDC/JWT admin auth. Configure issuer/audience/JWKS URL in
# /var/lib/prodex/policy.toml under [gateway.sso].
# oidc_issuer = "https://idp.example"
# oidc_audience = "prodex-gateway"
# oidc_jwks_url = "https://idp.example/.well-known/jwks.json" # optional
# oidc_tenant_claim = "prodex_tenant"

# Optional shared gateway state. Enable it in /var/lib/prodex/policy.toml with:
# [gateway.state]
# backend = "postgres"
# postgres_url_env = "PRODEX_GATEWAY_POSTGRES_URL"
# PRODEX_GATEWAY_POSTGRES_URL=postgres://prodex:prodex@postgres:5432/prodex
#
# Or:
# [gateway.state]
# backend = "redis"
# redis_url_env = "PRODEX_GATEWAY_REDIS_URL"
# PRODEX_GATEWAY_REDIS_URL=redis://redis:6379/0

# Default compose command runs the OpenAI-compatible gateway path.
OPENAI_API_KEY=replace-me

# Optional OpenAI-compatible upstream override.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional provider bridge credentials. If you use one of these, also edit
# compose.yaml command, for example:
# command: ["gateway", "--listen", "0.0.0.0:4000", "--provider", "gemini"]
# GEMINI_API_KEY=replace-me
# ANTHROPIC_API_KEY=replace-me
# DEEPSEEK_API_KEY=replace-me
# GITHUB_COPILOT_API_KEY=replace-me
