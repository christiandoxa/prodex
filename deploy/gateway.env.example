# Copy this file to deploy/gateway.env before running Docker Compose.
# These values are paths to local secret files, never the secret values.

PRODEX_GATEWAY_TOKEN_FILE=./deploy/secrets/PRODEX_GATEWAY_TOKEN
OPENAI_API_KEY_FILE=./deploy/secrets/OPENAI_API_KEY
PRODEX_GATEWAY_POSTGRES_URL_FILE=./deploy/secrets/PRODEX_GATEWAY_POSTGRES_URL
PRODEX_GATEWAY_REDIS_URL_FILE=./deploy/secrets/PRODEX_GATEWAY_REDIS_URL
PRODEX_POSTGRES_PASSWORD_FILE=./deploy/secrets/PRODEX_POSTGRES_PASSWORD

# Optional non-secret database identifiers for the bundled Postgres profile.
PRODEX_POSTGRES_DB=prodex
PRODEX_POSTGRES_USER=prodex
