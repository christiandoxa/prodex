{
  "name": "prodex-workspace",
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "npm/prodex",
    "npm/prodex-gateway-sdk",
    "npm/platforms/*"
  ],
  "scripts": {
    "npm:version": "node scripts/npm/version.mjs",
    "npm:sync-version": "node scripts/npm/sync-version.mjs --root npm && node scripts/npm/sync-docs-version.mjs",
    "npm:sync-docs-version": "node scripts/npm/sync-docs-version.mjs",
    "installer:test": "node --test scripts/install.test.mjs",
    "changelog": "node scripts/npm/changelog.mjs",
    "changelog:check": "node scripts/npm/changelog.mjs --check",
    "changelog:ci-check": "node scripts/npm/changelog.mjs --ci-check",
    "changelog:test": "node --test scripts/npm/changelog.test.mjs",
    "compat:capture": "node scripts/compat/capture-replay.mjs",
    "compat:replay-fixtures": "node scripts/compat/capture-replay-fixture-tests.mjs",
    "compat:offline-gate": "npm run compat:check && npm run compat:replay-fixtures",
    "compat:check": "node scripts/compat/check-upstream-baseline.mjs",
    "compat:watch": "node scripts/compat/watch-upstream.mjs",
    "compat:watch-fixtures": "node scripts/compat/watch-upstream-fixture-tests.mjs",
    "compat:watch-ci": "node scripts/compat/watch-upstream-ci.mjs",
    "catalog:providers": "node scripts/catalog/provider-catalog-check.mjs",
    "catalog:providers:json": "node scripts/catalog/provider-catalog-check.mjs --json",
    "catalog:providers:test": "node --test scripts/catalog/provider-catalog-check.test.mjs",
    "sdk:gateway:test": "node --test npm/prodex-gateway-sdk/test/*.test.mjs",
    "load:mock-upstream": "node tests/load/mock-upstream.mjs",
    "load:runtime-proxy": "node tests/load/runtime-proxy-load.mjs",
    "load:self-test": "node tests/load/mock-upstream.mjs --self-test && node tests/load/runtime-proxy-load.mjs --self-test",
    "release:prepare": "node scripts/npm/release-prepare.mjs",
    "release:cut": "node scripts/npm/release-cut.mjs",
    "release:run": "node scripts/npm/release-run.mjs",
    "release:cargo-plan": "node scripts/npm/release-run.mjs --cargo-publish plan",
    "release:cargo-dry-run": "node scripts/npm/release-run.mjs --cargo-publish dry-run",
    "release:cargo-publish": "node scripts/npm/release-run.mjs --cargo-publish publish",
    "docs:lint": "node scripts/docs/lint-markdown.mjs && npm run docs:runtime-policy:self-test && npm run docs:runtime-policy:check",
    "docs:provider-capabilities": "node scripts/catalog/provider-capability-matrix.mjs --write",
    "docs:provider-capabilities:check": "node scripts/catalog/provider-capability-matrix.mjs",
    "docs:runtime-policy": "node scripts/docs/runtime-policy.mjs --write",
    "docs:runtime-policy:self-test": "node scripts/docs/runtime-policy.mjs --self-test",
    "docs:runtime-policy:check": "node scripts/docs/runtime-policy.mjs --check",
    "test": "npm run test:fast --",
    "test:full": "node scripts/ci/full-rust-test.mjs",
    "test:changed": "node scripts/ci/changed-tests.mjs",
    "test:fast": "node scripts/ci/test-fast.mjs",
    "test:fast:timings": "node scripts/ci/test-fast.mjs --timings",
    "test:auto-rotate-shards": "node scripts/ci/auto-rotate-shards.mjs",
    "test:timing-balance": "node scripts/ci/timing-auto-balance.mjs",
    "test:runtime-smoke": "node scripts/ci/test-serial.mjs --suite runtime-smoke",
    "test:gemini-live": "node scripts/ci/gemini-live-smoke.mjs",
    "test:gemini-schema": "cargo test -q -p prodex-provider-core gemini_provider_core_ && cargo test -q -p prodex-app --lib gemini_",
    "test:serial": "node scripts/ci/test-serial.mjs",
    "test:serial:timings": "node scripts/ci/test-serial.mjs --timings",
    "ci:changed": "node scripts/ci/changed-tests.mjs",
    "ci:install-hooks": "git config core.hooksPath scripts/git-hooks",
    "ci:prepush": "node scripts/ci/prepush.mjs",
    "ci:preflight": "node scripts/ci/preflight.mjs",
    "ci:impact": "node --test scripts/ci/ci-impact.test.mjs",
    "ci:allow-guard": "node scripts/ci/allow-attribute-guard.mjs",
    "ci:super-wildcard-guard": "node scripts/ci/super-wildcard-guard.mjs",
    "ci:env-mutation-guard": "node scripts/ci/env-mutation-guard.mjs",
    "ci:secret-boundary-guard": "node scripts/ci/secret-boundary-guard.mjs --self-test",
    "ci:supply-chain-guard": "node scripts/ci/supply-chain-guard.mjs --self-test",
    "ci:enterprise-docs-guard": "node scripts/ci/enterprise-docs-guard.mjs --self-test && node scripts/ci/enterprise-docs-guard.mjs",
    "ci:enterprise-id-boundary-guard": "node scripts/ci/enterprise-id-boundary-guard.mjs --self-test && node scripts/ci/enterprise-id-boundary-guard.mjs",
    "ci:enterprise-binaries-guard": "node scripts/ci/enterprise-binaries-guard.mjs --self-test && node scripts/ci/enterprise-binaries-guard.mjs",
    "ci:size-guard": "node scripts/ci/size-guard.mjs",
    "ci:size-guard-fixtures": "node --test scripts/ci/size-guard.test.mjs",
    "ci:dependency-duplicates": "node scripts/ci/dependency-duplicate-guard.mjs",
    "ci:dependency-duplicates-fixtures": "node --test scripts/ci/dependency-duplicate-guard.test.mjs",
    "ci:crate-boundary": "node scripts/ci/crate-boundary-guard.mjs --self-test && node scripts/ci/crate-boundary-guard.mjs",
    "ci:churn-hygiene-fixtures": "node scripts/ci/churn-hygiene-fixture-tests.mjs",
    "ci:release-hygiene": "node scripts/ci/release-hygiene.mjs",
    "ci:generated-metadata-clean": "node scripts/ci/generated-metadata-clean.mjs",
    "ci:release-metadata-guard": "node scripts/ci/release-metadata-only-guard.mjs",
    "ci:version-metadata-release-guard": "node scripts/ci/version-metadata-release-guard.mjs",
    "ci:release-empty-commit-guard": "node scripts/ci/release-empty-commit-guard.mjs",
    "ci:release-duplicate-version-guard": "node scripts/ci/release-duplicate-version-guard.mjs",
    "ci:release-tag-changelog-guard": "node scripts/ci/release-tag-changelog-guard.mjs",
    "ci:release-guard-fixtures": "node scripts/ci/release-guard-fixture-tests.mjs",
    "ci:release-cut-fixtures": "node scripts/ci/release-cut-fixture-tests.mjs",
    "ci:runtime-hotpath-guard": "node scripts/ci/runtime-hotpath-guard.mjs --self-test && node scripts/ci/runtime-hotpath-guard.mjs",
    "ci:runtime-load-smoke": "npm run load:self-test && node scripts/ci/runtime-load-smoke.mjs",
    "ci:churn-hygiene": "node scripts/ci/churn-hygiene.mjs",
    "ci:churn-hygiene:check": "node scripts/ci/churn-hygiene.mjs --check",
    "ci:runtime-manifest": "node scripts/ci/runtime-test-manifest-guard.mjs",
    "ci:runtime-stress": "node scripts/ci/runtime-stress.mjs",
    "ci:gateway-security-smoke": "cargo test -q -p prodex-app gateway_admin_auth -- --test-threads=1 && cargo test -q -p prodex-app gateway_usage -- --test-threads=1",
    "ci:failed-jobs": "node scripts/ci/github-failure-summary.mjs",
    "ci:job-durations": "node scripts/ci/github-job-durations.mjs",
    "ci:application-boundary-guard": "node scripts/ci/application-boundary-guard.mjs --self-test && node scripts/ci/application-boundary-guard.mjs",
    "ci:production-boundary-guard": "node scripts/ci/production-boundary-guard.mjs --self-test && node scripts/ci/production-boundary-guard.mjs",
    "ci:auth-boundary-guard": "node scripts/ci/auth-boundary-guard.mjs --self-test && node scripts/ci/auth-boundary-guard.mjs",
    "ci:config-boundary-guard": "node scripts/ci/config-boundary-guard.mjs --self-test && node scripts/ci/config-boundary-guard.mjs",
    "ci:control-plane-boundary-guard": "node scripts/ci/control-plane-boundary-guard.mjs --self-test && node scripts/ci/control-plane-boundary-guard.mjs",
    "ci:domain-boundary-guard": "node scripts/ci/domain-boundary-guard.mjs --self-test && node scripts/ci/domain-boundary-guard.mjs",
    "ci:observability-boundary-guard": "node scripts/ci/observability-boundary-guard.mjs --self-test && node scripts/ci/observability-boundary-guard.mjs",
    "ci:provider-spi-boundary-guard": "node scripts/ci/provider-spi-boundary-guard.mjs --self-test && node scripts/ci/provider-spi-boundary-guard.mjs",
    "ci:storage-boundary-guard": "node scripts/ci/storage-boundary-guard.mjs --self-test && node scripts/ci/storage-boundary-guard.mjs",
    "ci:backup-restore-drill": "node scripts/ci/backup-restore-drill.mjs --self-test && node scripts/ci/backup-restore-drill.mjs",
    "ci:storage-postgres-proof": "node scripts/ci/storage-postgres-proof.mjs --self-test && node scripts/ci/storage-postgres-proof.mjs",
    "ci:storage-postgres-boundary-guard": "node scripts/ci/storage-postgres-boundary-guard.mjs --self-test && node scripts/ci/storage-postgres-boundary-guard.mjs",
    "ci:storage-redis-boundary-guard": "node scripts/ci/storage-redis-boundary-guard.mjs --self-test && node scripts/ci/storage-redis-boundary-guard.mjs",
    "ci:storage-sqlite-boundary-guard": "node scripts/ci/storage-sqlite-boundary-guard.mjs --self-test && node scripts/ci/storage-sqlite-boundary-guard.mjs",
    "ci:deployment-security-guard": "node scripts/ci/deployment-security-guard.mjs --self-test && node scripts/ci/deployment-security-guard.mjs",
    "ci:gateway-core-boundary-guard": "node scripts/ci/gateway-core-boundary-guard.mjs --self-test && node scripts/ci/gateway-core-boundary-guard.mjs",
    "ci:gateway-http-boundary-guard": "node scripts/ci/gateway-http-boundary-guard.mjs --self-test && node scripts/ci/gateway-http-boundary-guard.mjs"
  }
}
