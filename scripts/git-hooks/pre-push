#!/usr/bin/env sh
set -eu

if [ "${PRODEX_SKIP_PREPUSH:-}" = "1" ]; then
  exit 0
fi

# Let test fixtures discover their own repositories instead of inheriting this hook's Git paths.
unset GIT_DIR GIT_WORK_TREE GIT_COMMON_DIR GIT_INDEX_FILE GIT_OBJECT_DIRECTORY GIT_ALTERNATE_OBJECT_DIRECTORIES

npm run ci:prepush
