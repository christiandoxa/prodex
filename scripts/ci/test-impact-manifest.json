    },
    "churnHygieneRelevant": {
      "exact": [
        "package.json",
        "scripts/ci/changed-tests.mjs",
        "scripts/ci/churn-hygiene.mjs",
        "scripts/ci/churn-hygiene-fixture-tests.mjs",
        "scripts/ci/test-impact-manifest.json",
